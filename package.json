{
	"name": "verso",
	"version": "0.1.0",
	"description": "Verso — verifiable source for scientific papers",
	"type": "module",
	"scripts": {
		"build:data:round1": "cargo run --release --bin gen_data -- --count 10000 --seed 42 --min-complexity 3 --max-complexity 12",
		"build:data:round2": "cargo run --release --bin gen_data -- --count 10000 --seed 43 --min-complexity 8 --max-complexity 20",
		"build:data:round3": "cargo run --release --bin gen_data -- --count 10000 --seed 44",
		"build:data:rules": "cargo run --release --bin gen_rule_data -- --count-per-rule 50 --seed 100",
		"build:data": "npm run build:data:round1 && npm run build:data:round2 && npm run build:data:round3 && npm run build:data:rules",
		"lint": "eslint .",
		"repl": "cargo run --release -p verso_training --bin ml_repl -- --device ndarray",
		"repl:beam": "cargo run -p verso_symbolic --release --bin repl",
		"ml:reset": "rm -rf data_training checkpoints",
		"train": "cargo run --release -p verso_training --bin policy_train -- --device wgpu",
		"evaluate": "cargo run --release -p verso_training --bin policy_evaluate -- --device ndarray",
		"rl-train": "cargo run --release -p verso_training --bin policy_rl_train -- --device ndarray",
		"check": "cargo run --release -p verso_doc --bin verso_check --",
		"compile": "cargo run --release -p verso_doc --bin verso_compile --",
		"watch": "cargo run --release -p verso_doc --bin verso_watch --",
		"vscode:install": "cargo build --release -p verso_doc --bin verso_lsp && cd editors/vscode && npx tsc -p ./ && npx @vscode/vsce package --allow-missing-repository && code --install-extension verso-lang-0.1.0.vsix --force",
		"test": "cargo test --workspace && npm run lint"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@types/eslint__js": "^8.42.3",
		"@types/node": "^25.2.0",
		"eslint": "^9.39.2",
		"glob": "^13.0.0",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0"
	}
}
