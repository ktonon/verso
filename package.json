{
	"name": "ogma",
	"version": "0.1.0",
	"description": "Ogma — verifiable source for scientific papers",
	"type": "module",
	"scripts": {
		"build:data:round1": "cargo run --release --bin gen_data -- --count 10000 --seed 42 --min-complexity 3 --max-complexity 12",
		"build:data:round2": "cargo run --release --bin gen_data -- --count 10000 --seed 43 --min-complexity 8 --max-complexity 20",
		"build:data:round3": "cargo run --release --bin gen_data -- --count 10000 --seed 44",
		"build:data:rules": "cargo run --release --bin gen_rule_data -- --count-per-rule 50 --seed 100",
		"build:data": "npm run build:data:round1 && npm run build:data:round2 && npm run build:data:round3 && npm run build:data:rules",
		"lint": "eslint .",
		"repl": "cargo run -p ogma_symbolic --release --bin repl",
		"ml:reset": "rm -rf data_training checkpoints",
		"train": "cargo run --release -p ogma_training --bin policy_train -- --device wgpu",
		"evaluate": "cargo run --release -p ogma_training --bin policy_evaluate -- --device ndarray",
		"rl-train": "cargo run --release -p ogma_training --bin policy_rl_train -- --device ndarray",
		"check": "cargo run --release -p ogma_doc --bin ogma -- check",
		"build": "cargo run --release -p ogma_doc --bin ogma -- build",
		"watch": "cargo run --release -p ogma_doc --bin ogma -- watch",
		"install:local": "cargo install --path ogma_doc && npm run vscode:install",
		"vscode:install": "cargo build --release -p ogma_doc --bin ogma && cd editors/vscode && npx tsc -p ./ && npx @vscode/vsce package --allow-missing-repository && code --install-extension ogma-lang-0.1.0.vsix --force",
		"test:js": "node --test scripts/*.test.mjs",
		"test": "cargo test --workspace && npm run test:js && npm run lint",
		"coverage": "cargo llvm-cov --workspace --html && echo 'Report: target/llvm-cov/html/index.html'",
		"coverage:summary": "cargo llvm-cov --workspace",
		"coverage:modules": "node scripts/coverage-modules.mjs"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@types/eslint__js": "^8.42.3",
		"@types/node": "^25.2.0",
		"eslint": "^9.39.2",
		"glob": "^13.0.0",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0"
	}
}
