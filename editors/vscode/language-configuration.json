{
  "comments": {
    "lineComment": "%"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "{", "close": "}" },
    { "open": "`", "close": "`" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"],
    ["`", "`"],
    ["\"", "\""],
    ["'", "'"],
    ["*", "*"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(:claim|:proof|:dim|:theorem|:lemma|:definition|:corollary|:remark|:example|:bibliography|```math|>)",
      "end": "^\\s*$|^\\s*```\\s*$"
    }
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
