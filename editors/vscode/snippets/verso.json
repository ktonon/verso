{
  "Claim": {
    "prefix": "claim",
    "body": [
      "!claim ${1:name}",
      "  ${2:lhs} = ${3:rhs}",
      ""
    ],
    "description": "New claim block"
  },
  "Proof": {
    "prefix": "proof",
    "body": [
      "!proof ${1:name}",
      "  ${2:expr}",
      "  = ${3:step}",
      ""
    ],
    "description": "New proof block"
  },
  "Variable": {
    "prefix": "var",
    "body": [
      "!var ${1:name} [${2:dims}]"
    ],
    "description": "Variable declaration with dimensions"
  },
  "Constant": {
    "prefix": "const",
    "body": [
      "!const ${1:name} = ${2:value}"
    ],
    "description": "Constant declaration"
  },
  "Function": {
    "prefix": "func",
    "body": [
      "!func ${1:name}(${2:params}) = ${3:body}"
    ],
    "description": "Function declaration"
  },
  "Theorem": {
    "prefix": "thm",
    "body": [
      "!theorem ${1:Title}",
      "  ${2:body}",
      ""
    ],
    "description": "Theorem environment"
  },
  "Lemma": {
    "prefix": "lem",
    "body": [
      "!lemma ${1:Title}",
      "  ${2:body}",
      ""
    ],
    "description": "Lemma environment"
  },
  "Definition": {
    "prefix": "def",
    "body": [
      "!definition ${1:Title}",
      "  ${2:body}",
      ""
    ],
    "description": "Definition environment"
  },
  "Math Block": {
    "prefix": "mathb",
    "body": [
      "```math",
      "${1:expr}",
      "```",
      ""
    ],
    "description": "Fenced math block"
  },
  "Inline Math": {
    "prefix": "math",
    "body": [
      "math`${1:expr}`"
    ],
    "description": "Inline math expression"
  },
  "Inline TeX": {
    "prefix": "tex",
    "body": [
      "tex`${1:latex}`"
    ],
    "description": "Inline raw LaTeX"
  },
  "Citation": {
    "prefix": "cite",
    "body": [
      "cite`${1:key}`"
    ],
    "description": "Bibliography citation"
  },
  "Claim Reference": {
    "prefix": "cref",
    "body": [
      "claim`${1:name}`"
    ],
    "description": "Reference to a named claim"
  },
  "Cross Reference": {
    "prefix": "ref",
    "body": [
      "ref`${1:label}`"
    ],
    "description": "Cross-reference to a section"
  },
  "Cross Reference with Display Text": {
    "prefix": "refd",
    "body": [
      "ref`${1:label}|${2:display text}`"
    ],
    "description": "Cross-reference with custom display text"
  },
  "URL": {
    "prefix": "url",
    "body": [
      "url`${1:https://}`"
    ],
    "description": "Inline URL"
  },
  "URL with Display Text": {
    "prefix": "urld",
    "body": [
      "url`${1:https://}|${2:display text}`"
    ],
    "description": "Inline URL with custom display text"
  },
  "Bibliography": {
    "prefix": "bib",
    "body": [
      "!bibliography ${1:refs.bib}"
    ],
    "description": "Bibliography declaration"
  }
}
