{
  "name": "verso-lang",
  "displayName": "Verso Language Support",
  "description": "Language support for .verso documents — verified math papers",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "verso",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "verso",
        "extensions": [
          ".verso"
        ],
        "aliases": [
          "Verso",
          "verso"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "verso",
        "scopeName": "source.verso",
        "path": "./syntaxes/verso.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "verso",
        "path": "./snippets/verso.json"
      }
    ],
    "configurationDefaults": {
      "[verso]": {
        "editor.tabSize": 3,
        "editor.insertSpaces": false,
        "editor.wordWrap": "on"
      }
    },
    "configuration": {
      "title": "Verso",
      "properties": {
        "verso.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the verso binary. If empty, searches PATH and workspace target/release/."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "test": "vscode-tmgrammar-snap -g syntaxes/verso.tmLanguage.json tests/snap-*.verso",
    "package": "npm run compile && vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0",
    "vscode-tmgrammar-test": "^0.1.3"
  }
}
