{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Verso",
  "scopeName": "source.verso",
  "patterns": [
    { "include": "#comment" },
    { "include": "#heading" },
    { "include": "#math-block" },
    { "include": "#directive-claim" },
    { "include": "#directive-proof" },
    { "include": "#directive-var" },
    { "include": "#directive-def" },
    { "include": "#directive-func" },
    { "include": "#directive-bibliography" },
    { "include": "#directive-figure" },
    { "include": "#directive-table" },
    { "include": "#directive-toc" },
    { "include": "#directive-center" },
    { "include": "#directive-pagebreak" },
    { "include": "#directive-include" },
    { "include": "#directive-metadata" },
    { "include": "#directive-environment" },
    { "include": "#block-quote" },
    { "include": "#list-bullet" },
    { "include": "#list-numbered" },
    { "include": "#prose-inline" }
  ],
  "repository": {
    "comment": {
      "match": "^%.*$",
      "name": "comment.line.percentage.verso"
    },

    "heading": {
      "patterns": [
        {
          "begin": "^(#{4})\\s+",
          "end": "$",
          "beginCaptures": { "1": { "name": "punctuation.definition.heading.verso" } },
          "name": "markup.heading.4.verso",
          "patterns": [{ "include": "#tag-label" }, { "include": "#quoted-string" }]
        },
        {
          "begin": "^(#{3})\\s+",
          "end": "$",
          "beginCaptures": { "1": { "name": "punctuation.definition.heading.verso" } },
          "name": "markup.heading.3.verso",
          "patterns": [{ "include": "#tag-label" }, { "include": "#quoted-string" }]
        },
        {
          "begin": "^(#{2})\\s+",
          "end": "$",
          "beginCaptures": { "1": { "name": "punctuation.definition.heading.verso" } },
          "name": "markup.heading.2.verso",
          "patterns": [{ "include": "#tag-label" }, { "include": "#quoted-string" }]
        },
        {
          "begin": "^(#)\\s+",
          "end": "$",
          "beginCaptures": { "1": { "name": "punctuation.definition.heading.verso" } },
          "name": "markup.heading.1.verso",
          "patterns": [{ "include": "#tag-label" }, { "include": "#quoted-string" }]
        }
      ]
    },

    "math-block": {
      "begin": "^(```math)\\s*$",
      "end": "^(```)\\s*$",
      "beginCaptures": {
        "1": { "name": "keyword.control.fenced.begin.verso" }
      },
      "endCaptures": {
        "1": { "name": "keyword.control.fenced.end.verso" }
      },
      "name": "meta.block.math.verso",
      "patterns": [
        { "include": "#math-expression" }
      ]
    },

    "directive-claim": {
      "begin": "^(claim)\\s+(\\S+)\\s*$",
      "end": "^(?=\\S|$(?!\\s))",
      "beginCaptures": {
        "1": { "name": "keyword.control.directive.claim.verso" },
        "2": { "name": "entity.name.function.claim.verso" }
      },
      "name": "meta.block.claim.verso",
      "patterns": [
        { "include": "#claim-body" }
      ]
    },

    "claim-body": {
      "match": "^\\s+(.+?)\\s*(=)\\s*(.+)$",
      "captures": {
        "1": { "name": "meta.expression.lhs.verso", "patterns": [{ "include": "#math-expression" }] },
        "2": { "name": "keyword.operator.equals.verso" },
        "3": { "name": "meta.expression.rhs.verso", "patterns": [{ "include": "#math-expression" }] }
      }
    },

    "directive-proof": {
      "begin": "^(proof)\\s+(\\S+)\\s*$",
      "end": "^(?=\\S|$(?!\\s))",
      "beginCaptures": {
        "1": { "name": "keyword.control.directive.proof.verso" },
        "2": { "name": "entity.name.function.proof.verso" }
      },
      "name": "meta.block.proof.verso",
      "patterns": [
        { "include": "#proof-step" }
      ]
    },

    "proof-step": {
      "patterns": [
        {
          "match": "^\\s+(=)\\s*(.+?)\\s*(;\\s*.+)?$",
          "captures": {
            "1": { "name": "keyword.operator.proof-step.verso" },
            "2": { "name": "meta.expression.verso", "patterns": [{ "include": "#math-expression" }] },
            "3": { "name": "comment.line.justification.verso" }
          }
        },
        {
          "match": "^\\s+(.+?)\\s*(;\\s*.+)?$",
          "captures": {
            "1": { "name": "meta.expression.verso", "patterns": [{ "include": "#math-expression" }] },
            "2": { "name": "comment.line.justification.verso" }
          }
        }
      ]
    },

    "directive-var": {
      "match": "^(var)\\s+(\\S+)\\s+(\\[.+\\])\\s*$",
      "captures": {
        "1": { "name": "keyword.control.directive.var.verso" },
        "2": { "name": "variable.parameter.var.verso" },
        "3": { "name": "storage.type.dimension.verso" }
      }
    },

    "directive-def": {
      "match": "^(def)\\s+(\\S+)\\s*(:=)\\s*(.+)$",
      "captures": {
        "1": { "name": "keyword.control.directive.def.verso" },
        "2": { "name": "variable.parameter.def.verso" },
        "3": { "name": "keyword.operator.definition.verso" },
        "4": { "name": "meta.expression.rhs.verso", "patterns": [{ "include": "#math-expression" }] }
      }
    },

    "directive-func": {
      "match": "^(func)\\s+(\\S+?)\\(([^)]+)\\)\\s*(:=)\\s*(.+)$",
      "captures": {
        "1": { "name": "keyword.control.directive.func.verso" },
        "2": { "name": "entity.name.function.verso" },
        "3": { "name": "variable.parameter.func.verso" },
        "4": { "name": "keyword.operator.assignment.verso" },
        "5": { "name": "meta.expression.rhs.verso", "patterns": [{ "include": "#math-expression" }] }
      }
    },

    "directive-bibliography": {
      "match": "^(!bibliography)\\s+(.+)$",
      "captures": {
        "1": { "name": "keyword.control.directive.bibliography.verso" },
        "2": { "name": "string.unquoted.path.verso" }
      }
    },

    "directive-figure": {
      "begin": "^(!figure)\\s+(.+)$",
      "end": "^(?!\\s)|^\\s*$",
      "beginCaptures": {
        "1": { "name": "keyword.control.directive.figure.verso" },
        "2": { "name": "string.unquoted.path.verso" }
      },
      "name": "meta.block.figure.verso",
      "patterns": [
        {
          "match": "^\\s+(caption|label|width)(:)\\s*(.*)$",
          "captures": {
            "1": { "name": "keyword.other.key.verso" },
            "2": { "name": "punctuation.separator.key-value.verso" },
            "3": { "name": "string.unquoted.value.verso" }
          }
        }
      ]
    },

    "directive-table": {
      "begin": "^(!table)(?:\\s+(.+))?\\s*$",
      "end": "^(?!\\s)|^\\s*$",
      "beginCaptures": {
        "1": { "name": "keyword.control.directive.table.verso" },
        "2": { "name": "entity.name.section.table.verso" }
      },
      "name": "meta.block.table.verso",
      "patterns": [
        {
          "match": "^\\s+(label)(:)\\s*(.*)$",
          "captures": {
            "1": { "name": "keyword.other.key.verso" },
            "2": { "name": "punctuation.separator.key-value.verso" },
            "3": { "name": "string.unquoted.value.verso" }
          }
        },
        {
          "match": "(\\|)",
          "name": "punctuation.separator.table.verso"
        }
      ]
    },

    "directive-toc": {
      "match": "^(!toc)\\s*$",
      "captures": {
        "1": { "name": "keyword.control.directive.toc.verso" }
      }
    },

    "directive-center": {
      "match": "^(!center)\\s*$",
      "captures": {
        "1": { "name": "keyword.control.directive.center.verso" }
      }
    },

    "directive-pagebreak": {
      "match": "^(!pagebreak)\\s*$",
      "captures": {
        "1": { "name": "keyword.control.directive.pagebreak.verso" }
      }
    },

    "directive-include": {
      "match": "^(!include)\\s+(.+)$",
      "captures": {
        "1": { "name": "keyword.control.directive.include.verso" },
        "2": { "name": "string.unquoted.path.verso" }
      }
    },

    "directive-metadata": {
      "patterns": [
        {
          "match": "^(!title)\\s+(.+)$",
          "captures": {
            "1": { "name": "keyword.control.directive.title.verso" },
            "2": { "name": "entity.name.section.title.verso" }
          }
        },
        {
          "begin": "^(!title)\\s*$",
          "end": "^(?!\\s|$)",
          "beginCaptures": {
            "1": { "name": "keyword.control.directive.title.verso" }
          },
          "name": "meta.block.title.verso",
          "patterns": [
            {
              "match": "^\\s+(.+)$",
              "captures": {
                "1": { "name": "entity.name.section.title.verso" }
              }
            }
          ]
        },
        {
          "match": "^(!author)\\s+(.+)$",
          "captures": {
            "1": { "name": "keyword.control.directive.author.verso" },
            "2": { "name": "string.other.author.verso" }
          }
        },
        {
          "match": "^(!date)\\s*(.*)$",
          "captures": {
            "1": { "name": "keyword.control.directive.date.verso" },
            "2": { "name": "constant.other.date.verso" }
          }
        },
        {
          "begin": "^(!abstract)\\s*$",
          "end": "^(?!\\s)|^\\s*$",
          "beginCaptures": {
            "1": { "name": "keyword.control.directive.abstract.verso" }
          },
          "name": "meta.block.abstract.verso",
          "patterns": [
            { "include": "#prose-inline" }
          ]
        }
      ]
    },

    "directive-environment": {
      "begin": "^(!(?:theorem|lemma|corollary|remark|example))(?:\\s+(.+))?\\s*$",
      "end": "^(?!\\s)|^\\s*$",
      "beginCaptures": {
        "1": { "name": "keyword.control.directive.environment.verso" },
        "2": { "name": "entity.name.section.environment.verso" }
      },
      "name": "meta.block.environment.verso",
      "patterns": [
        { "include": "#prose-inline" }
      ]
    },

    "block-quote": {
      "match": "^(>)\\s?(.*)$",
      "captures": {
        "1": { "name": "punctuation.definition.quote.verso" },
        "2": { "name": "markup.quote.verso", "patterns": [{ "include": "#prose-inline" }] }
      }
    },

    "list-bullet": {
      "match": "^(\\s*)(-)\\s+(.+)$",
      "captures": {
        "1": { "name": "punctuation.whitespace.verso" },
        "2": { "name": "punctuation.definition.list.begin.verso" },
        "3": { "name": "meta.list.item.verso", "patterns": [{ "include": "#prose-inline" }] }
      }
    },

    "list-numbered": {
      "match": "^(\\s*)(\\d+\\.)\\s+(.+)$",
      "captures": {
        "1": { "name": "punctuation.whitespace.verso" },
        "2": { "name": "punctuation.definition.list.begin.verso" },
        "3": { "name": "meta.list.item.verso", "patterns": [{ "include": "#prose-inline" }] }
      }
    },

    "prose-inline": {
      "patterns": [
        { "include": "#tag-math" },
        { "include": "#tag-tex" },
        { "include": "#tag-claim" },
        { "include": "#tag-cite" },
        { "include": "#tag-ref" },
        { "include": "#tag-url" },
        { "include": "#tag-sym" },
        { "include": "#quoted-string" },
        { "include": "#footnote" },
        { "include": "#bold-italic" },
        { "include": "#bold" },
        { "include": "#italic" }
      ]
    },

    "tag-math": {
      "match": "(math)(`)((?:[^`\\\\]|\\\\.)*)(`)",
      "captures": {
        "1": { "name": "keyword.other.tag.math.verso" },
        "2": { "name": "string.other.begin.verso" },
        "3": { "name": "string.other.math.verso", "patterns": [{ "include": "#math-expression" }] },
        "4": { "name": "string.other.end.verso" }
      }
    },

    "tag-tex": {
      "match": "(tex)(`)((?:[^`\\\\]|\\\\.)*)(`)",
      "captures": {
        "1": { "name": "keyword.other.tag.tex.verso" },
        "2": { "name": "string.other.begin.verso" },
        "3": { "name": "string.other.tex.verso" },
        "4": { "name": "string.other.end.verso" }
      }
    },

    "tag-claim": {
      "match": "(claim)(`)((?:[^`\\\\]|\\\\.)*)(`)",
      "captures": {
        "1": { "name": "keyword.other.tag.claim.verso" },
        "2": { "name": "string.other.begin.verso" },
        "3": { "name": "entity.name.function.claim-ref.verso" },
        "4": { "name": "string.other.end.verso" }
      }
    },

    "tag-cite": {
      "match": "(cite)(`)((?:[^`\\\\]|\\\\.)*)(`)",
      "captures": {
        "1": { "name": "keyword.other.tag.cite.verso" },
        "2": { "name": "string.other.begin.verso" },
        "3": { "name": "string.other.citation.verso" },
        "4": { "name": "string.other.end.verso" }
      }
    },

    "tag-ref": {
      "match": "(ref)(`)((?:[^`|\\\\]|\\\\.)*)(?:(\\|)((?:[^`\\\\]|\\\\.)*))?(`)",
      "captures": {
        "1": { "name": "keyword.other.tag.ref.verso" },
        "2": { "name": "string.other.begin.verso" },
        "3": { "name": "entity.name.tag.cross-ref.verso" },
        "4": { "name": "punctuation.separator.pipe.verso" },
        "5": { "name": "string.other.display-text.verso" },
        "6": { "name": "string.other.end.verso" }
      }
    },

    "tag-url": {
      "match": "(url)(`)((?:[^`|\\\\]|\\\\.)*)(?:(\\|)((?:[^`\\\\]|\\\\.)*))?(`)",
      "captures": {
        "1": { "name": "keyword.other.tag.url.verso" },
        "2": { "name": "string.other.begin.verso" },
        "3": { "name": "markup.underline.link.verso" },
        "4": { "name": "punctuation.separator.pipe.verso" },
        "5": { "name": "string.other.display-text.verso" },
        "6": { "name": "string.other.end.verso" }
      }
    },

    "tag-sym": {
      "match": "(sym)(`)((?:[^`|\\\\]|\\\\.)*)(?:(\\|)((?:[^`\\\\]|\\\\.)*))?(`)",
      "captures": {
        "1": { "name": "keyword.other.tag.sym.verso" },
        "2": { "name": "string.other.begin.verso" },
        "3": { "name": "entity.name.tag.symbol-ref.verso" },
        "4": { "name": "punctuation.separator.pipe.verso" },
        "5": { "name": "string.other.display-text.verso" },
        "6": { "name": "string.other.end.verso" }
      }
    },

    "tag-label": {
      "match": "(label)(`)((?:[^`\\\\]|\\\\.)*)(`)",
      "captures": {
        "1": { "name": "keyword.other.tag.label.verso" },
        "2": { "name": "string.other.begin.verso" },
        "3": { "name": "entity.name.tag.label.verso" },
        "4": { "name": "string.other.end.verso" }
      }
    },

    "quoted-string": {
      "match": "\"([^\"]*)\"",
      "name": "markup.italic.quote.verso"
    },

    "footnote": {
      "begin": "(\\^)(\\[)",
      "end": "(\\])",
      "beginCaptures": {
        "1": { "name": "keyword.other.footnote.verso" },
        "2": { "name": "punctuation.definition.footnote.begin.verso" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.footnote.end.verso" }
      },
      "name": "markup.other.footnote.verso",
      "patterns": [
        { "include": "#prose-inline" }
      ]
    },

    "bold-italic": {
      "begin": "(\\*{3})(?=\\S)",
      "end": "(\\*{3})",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.bold.italic.verso" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.bold.italic.verso" }
      },
      "name": "markup.bold.verso",
      "patterns": [
        {
          "begin": "(?<=\\*{3})",
          "end": "(?=\\*{3})",
          "name": "markup.italic.verso",
          "patterns": [
            { "include": "#prose-inline" }
          ]
        }
      ]
    },

    "bold": {
      "begin": "(\\*{2})(?=\\S)",
      "end": "(\\*{2})",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.bold.verso" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.bold.verso" }
      },
      "name": "markup.bold.verso",
      "patterns": [
        { "include": "#prose-inline" }
      ]
    },

    "italic": {
      "begin": "(\\*)(?=[^\\s*])",
      "end": "(\\*)(?!\\*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.italic.verso" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.italic.verso" }
      },
      "name": "markup.italic.verso",
      "patterns": [
        { "include": "#prose-inline" }
      ]
    },

    "math-expression": {
      "patterns": [
        {
          "include": "#bracket-annotation"
        },
        {
          "match": "\\b(sin|cos|tan|asin|acos|atan|sinh|cosh|tanh|sqrt|exp|log|ln|abs|det|tr)\\b",
          "name": "entity.name.function.math.verso"
        },
        {
          "match": "\\b(pi|π)\\b",
          "name": "constant.language.pi.verso"
        },
        {
          "match": "\\be\\b",
          "name": "constant.language.euler.verso"
        },
        {
          "match": "\\b\\d[\\d_]*(\\.[\\d_]+)?",
          "name": "constant.numeric.decimal.verso"
        },
        {
          "match": "\\^",
          "name": "keyword.operator.power.verso"
        },
        {
          "match": "[+\\-*/=]",
          "name": "keyword.operator.arithmetic.verso"
        },
        {
          "match": "[()]",
          "name": "punctuation.brackets.round.verso"
        },
        {
          "match": "&",
          "name": "keyword.operator.alignment.verso"
        }
      ]
    },

    "bracket-annotation": {
      "begin": "(\\[)",
      "end": "(\\])",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.bracket.begin.verso" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.bracket.end.verso" }
      },
      "name": "meta.bracket-annotation.verso",
      "patterns": [
        {
          "comment": "Base dimension symbols: L, M, T, Theta, I, N, J",
          "match": "\\b(L|M|T|Theta|I|N|J)\\b",
          "name": "storage.type.dimension.verso"
        },
        {
          "comment": "SI derived units",
          "match": "\\b(Hz|Pa|Ohm)\\b",
          "name": "storage.type.unit.verso"
        },
        {
          "comment": "SI base and derived unit symbols (single/multi-char)",
          "match": "\\b[pnμmckMGT]?(m|g|s|K|A|mol|cd|N|J|W|C|V)\\b",
          "name": "storage.type.unit.verso"
        },
        {
          "match": "\\b(kg)\\b",
          "name": "storage.type.unit.verso"
        },
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.decimal.verso"
        },
        {
          "match": "[\\^/\\*\\-]",
          "name": "keyword.operator.verso"
        }
      ]
    }
  }
}
